NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/house-of-rani?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# CORS
FRONTEND_URL=http://localhost:3000

# ── Email (Gmail inbox / not spam: DNS + auth matter more than code) ─────────
# 1) Send from YOUR domain (e.g. noreply@yourdomain.com), not a random Gmail address,
#    unless you use that Gmail account’s SMTP with “Send mail as” verified.
# 2) In DNS for the domain: publish SPF (include your SMTP provider), DKIM (provider or below),
#    and DMARC (e.g. _dmarc TXT v=DMARC1; p=none; rua=mailto:you@yourdomain.com — tighten later).
# 3) Use a reputable SMTP (Google Workspace, Resend, SendGrid, Mailgun, Amazon SES, etc.).
# 4) MAIL_REPLY_TO should be a monitored address on the same domain when possible.
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true
# SMTP_USER=your-address@gmail.com
# SMTP_PASS=app-specific-password
#
# MAIL_FROM=The House of Rani <noreply@yourdomain.com>
# MAIL_REPLY_TO=support@yourdomain.com
#
# Optional: sign mail with DKIM (private key PEM). Improves Gmail trust if DNS TXT matches.
# DKIM_DOMAIN=yourdomain.com
# DKIM_SELECTOR=default
# DKIM_PRIVATE_KEY_PATH=/path/to/dkim-private.pem
# Or single-line PEM with \n for newlines:
# DKIM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Redis (BullMQ / rate limit). Prefer one URL, or omit URL and use HOST/PORT/PASSWORD.
# Redis Cloud: password required; TLS often needs rediss:// (double s).
# REDIS_URL=redis://default:YOUR_PASSWORD@redis-xxxxx.cloud.redislabs.com:14167
# REDIS_URL=rediss://default:YOUR_PASSWORD@redis-xxxxx.cloud.redislabs.com:14167
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
